{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix client ci && npm --prefix server ci",
  "buildCommand": "npm --prefix client run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
